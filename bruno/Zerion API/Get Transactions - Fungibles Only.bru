meta {
  name: Get Transactions - Fungibles Only
  type: http
  seq: 5
}

get {
  url: {{ZERION_BASE_URL}}/wallets/{{WALLET_ADDRESS}}/transactions/?filter[chain_ids]=base&filter[asset_types]=fungible&filter[trash]=only_non_trash
  body: none
  auth: basic
}

auth:basic {
  username: {{ZERION_API_KEY}}
  password:
}

headers {
  Accept: application/json
}
